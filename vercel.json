{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-API-Version", "value": "1.0" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/privacy-policy",
      "destination": "/api/legal/privacy-policy",
      "permanent": false
    },
    {
      "source": "/privacy-policy/",
      "destination": "/api/legal/privacy-policy",
      "permanent": false
    },
    {
      "source": "/terms-of-service",
      "destination": "/api/legal/terms-of-service", 
      "permanent": false
    },
    {
      "source": "/terms-of-service/",
      "destination": "/api/legal/terms-of-service",
      "permanent": false
    },
    {
      "source": "/affiliate-disclosure",
      "destination": "/api/legal/affiliate-disclosure",
      "permanent": false
    },
    {
      "source": "/affiliate-disclosure/",
      "destination": "/api/legal/affiliate-disclosure", 
      "permanent": false
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots",
      "permanent": false
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap",
      "permanent": false
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node"
    }
  }
}